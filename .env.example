# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8000
APP_API_SUBPATH=/api

# --- OpenSearch ---
# For local dev via `docker-compose up opensearch`, use:
#   OPENSEARCH_ENDPOINT=http://localhost:9200
#   OPENSEARCH_USE_SSL=false
#   OPENSEARCH_VERIFY_CERTS=false
# For a real cluster (AWS OpenSearch Service, etc.), use https + leave SSL settings at their secure defaults.
OPENSEARCH_ENDPOINT=https://localhost:9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_USE_SSL=true
OPENSEARCH_VERIFY_CERTS=true

# --- OpenSearch indices (rename the docintel_ prefix per-fork) ---
AOS_USER_INDEX=docintel_users_teams
AOS_TEAM_INDEX=docintel_teams
AOS_DOCUMENTS_INDEX=docintel_documents
AOS_MESSAGES_INDEX=docintel_messages
AOS_LANGUAGES_INDEX=docintel_languages
AOS_PRIVATE_DOCUMENTS_INDEX=docintel_private_documents
AOS_AUDIT_INDEX=docintel_audit_logs

# --- Auth (local JWT) ---
# CHANGE THIS SECRET before any real deployment.
JWT_SECRET=change-me-before-deploying
JWT_ALGORITHM=HS256

# --- Auth (Azure AD SSO) — optional, leave blank to disable ---
AZURE_TENANT_ID=
AZURE_CLIENT_ID=

# --- AWS Bedrock ---
AWS_REGION=us-east-1
KNOWLEDGE_BASE_ID=
DATA_SOURCE_ID=
MODEL_ID=

# --- S3 ---
S3_BUCKET=
S3_FOLDER_PREFIX=
S3_UPLOADS_PREFIX=uploads/
S3_DOCS_PREFIX=docs/

# --- Team defaults ---
DEFAULT_TEAM_ID=
PRIVATE_TEAM_ID=

# --- Uploads ---
ALLOWED_EXTENSIONS=.pdf,.docx,.pptx,.ppt,.xlsx,.csv,.txt
CONVERSION_EXTENSIONS=.docx,.pptx,.ppt

# --- SMTP (optional, leave blank to disable email notifications) ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
EMAIL_SENDER_NAME=

# --- TLS (optional, only needed if running uvicorn with HTTPS directly) ---
SSL_KEYFILE=
SSL_CERTFILE=
